# .env.example - Template for environment variables
# Copy this file to .env and fill in your actual values
# This file is safe to commit to version control

#################################################
# Shared Settings
#################################################
# Timezone (used by most services)
TZ=America/Chicago

# Default user/group IDs for container permissions
PUID=1000
PGID=1000

# Hostname for containers that need an explicit hostname
NOVA_HOSTNAME=nova

# Absolute path to the primary user's home directory (used by backrest for home backup)
NOVA_USER_HOME=/home/your-username

#################################################
# Arcane - Container Management
# Stack: infra (docker-compose.infra.yaml)
#################################################
# Encryption key (exactly 32 characters)
# Generate with: openssl rand -hex 16
ARCANE_ENCRYPTION_KEY=your-32-char-encryption-key-here

# JWT secret for session signing
# Generate with: openssl rand -base64 32
ARCANE_JWT_SECRET=your-super-secret-jwt-key-change-this

#################################################
# Traefik - Reverse Proxy
# Stack: infra (docker-compose.infra.yaml)
#################################################
# Base domain for Traefik subdomain routing (your DuckDNS domain)
NOVA_DOMAIN=firefly-koonan.duckdns.org

#################################################
# HTTPS / Let's Encrypt
# Stack: infra (docker-compose.infra.yaml)
#################################################
# Email for Let's Encrypt certificate expiry notifications
ACME_EMAIL=your-email@example.com

#################################################
# DuckDNS - Dynamic DNS Service
# Stack: infra (docker-compose.infra.yaml)
#################################################
# Token for updating DuckDNS records
# Get token from: https://www.duckdns.org/
# Also used by Traefik for DNS-01 challenge (ACME certificate issuance)
DUCKDNS_TOKEN=your-duckdns-token-here

# DuckDNS subdomain name only (no .duckdns.org suffix)
# Example: if your domain is myserver.duckdns.org, set this to myserver
DUCKDNS_SUBDOMAIN=your-subdomain-here

#################################################
# Volume Sharer - Samba access to Docker volumes
# Stack: infra (docker-compose.infra.yaml)
#################################################
# UID/GID for the Samba user inside volume-sharer.
# Defaults to 0 (root) so all volume contents are readable regardless of
# file ownership. Override with your PUID/PGID if volumes are user-owned
# and you want to restrict Samba to user-readable files only.
#SAMBA_UID=0
#SAMBA_GID=0



#################################################
# Immich - Photo Management
# Stack: immich (docker-compose.immich.yaml)
#################################################
# Shared database password for all Immich services
# Used by: immich_machine_learning, immich_postgres, immich_server
# Generate with: openssl rand -base64 24
#################################################
# Immich - Photo Management
# Stack: immich (docker-compose.immich.yaml)
#################################################
# Shared database password for all Immich services
# Used by: immich_machine_learning, immich_postgres, immich_server
# Generate with: openssl rand -base64 24
IMMICH_DB_PASSWORD=pw
UPLOAD_LOCATION=path_in_container
DB_DATA_LOCATION=path_on_host
DB_USERNAME=postgres
DB_DATABASE_NAME=immich

#################################################
# Decluttarr - Download Queue Cleanup
# Stack: media (docker-compose.media.yaml)
#################################################
# API keys for Sonarr and Radarr
# Find in each app under Settings > General > Security > API Key
SONARR_API_KEY=your-sonarr-api-key-here
RADARR_API_KEY=your-radarr-api-key-here

#################################################
# Plex - Media Server
# Stack: media (docker-compose.media.yaml)
#################################################
# Claim token for linking Plex server to your account
# Get token from: https://www.plex.tv/claim/
# Note: Claim tokens expire after 4 minutes - obtain just before use
PLEX_CLAIM_TOKEN=claim-your-token-here

# Plex authentication token (used by Kometa)
# Find it at: https://support.plex.tv/articles/204059436-finding-an-authentication-token-x-plex-token/
PLEX_TOKEN=your-plex-token-here

#################################################
# Kometa - Plex Collection Manager
# Stack: media (docker-compose.media.yaml)
#################################################
# TMDb API key (required by Kometa for all metadata)
# Free key at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your-tmdb-api-key-here

# Radarr API key - find it in Radarr → Settings → General → API Key
RADARR_API_KEY=your-radarr-api-key-here

# Sonarr API key - find it in Sonarr → Settings → General → API Key
SONARR_API_KEY=your-sonarr-api-key-here

# Root folder path as configured in Sonarr (must match exactly)
# Check your Sonarr → Settings → Media Management → Root Folders
SONARR_ROOT_FOLDER=/plex_tv_1

# Root folder path as configured in Radarr (must match exactly)
# Check your Radarr → Settings → Media Management → Root Folders
# This is the container-side path, e.g. /plex_movies_1
RADARR_ROOT_FOLDER=/plex_movies_1

# Quality profile name in Radarr (must match exactly)
# Check your Radarr → Settings → Profiles
RADARR_QUALITY_PROFILE=HD-1080p

# Quality profile name in Sonarr (must match exactly)
# Check your Sonarr → Settings → Profiles
SONARR_QUALITY_PROFILE=HD-1080p

# Time to run Kometa daily (24h format, default 05:00)
# KOMETA_TIME=05:00

# MDbList API key (required for Rotten Tomatoes score overlays)
# Free key at: https://mdblist.com/preferences/#api
MDBLIST_API_KEY=your-mdblist-api-key-here

#################################################
# Gluetun - VPN Gateway (Mullvad WireGuard)
# Stack: media (docker-compose.media.yaml)
#################################################
# Mullvad WireGuard credentials
# Generate config at: https://mullvad.net/en/account/wireguard-config
# Download a WireGuard config file and extract values below
MULLVAD_WIREGUARD_PRIVATE_KEY=your-wireguard-private-key-base64
MULLVAD_WIREGUARD_ADDRESSES=10.x.x.x/32

# Server country for VPN exit (optional, defaults to Sweden)
#MULLVAD_SERVER_COUNTRY=Sweden

# Port forwarding port from Mullvad (optional — used by qBittorrent for seeding)
#MULLVAD_WIREGUARD_PORT_FORWARD=

#################################################
# qBittorrent - Torrent Client (via Gluetun VPN)
# Stack: media (docker-compose.media.yaml)
# WebUI: qbittorrent.NOVA_DOMAIN  Port: 8090
#################################################
# Used by decluttarr for real-time speed monitoring.
# Enable in qBittorrent WebUI: Tools → Options → Web UI → API Key.
QBITTORRENT_API_KEY=your-qbittorrent-api-key-here

#################################################
# Z-Wave JS UI - Smart Home Control
# Stack: home (docker-compose.home.yaml)
#################################################
# Session secret for securing web interface sessions
# Generate with: openssl rand -base64 32
ZWAVE_SESSION_SECRET=generate-a-secure-random-string

#################################################
# Vibe Kanban - Project Management
# Stack: dev (docker-compose.dev.yaml)
#################################################
# GitHub Personal Access Token for GitHub CLI (gh) authentication
# Create at: https://github.com/settings/tokens
# Required scopes (classic PAT): repo, read:org
GH_TOKEN=your-github-token-here

#################################################
# MovieNight - Movie Suggestion App
# Stack: movienight (docker-compose.movienight.yaml)
#################################################
# Database password for the MovieNight PostgreSQL instance
# Generate with: openssl rand -base64 24
MOVIENIGHT_DB_PASSWORD=your-movienight-db-password-here
