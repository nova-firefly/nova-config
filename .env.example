# .env.example - Template for environment variables
# Copy this file to .env and fill in your actual values
# This file is safe to commit to version control

#################################################
# DuckDNS - Dynamic DNS Service
#################################################
# Token for updating DuckDNS records
# Get token from: https://www.duckdns.org/
DUCKDNS_TOKEN=your-duckdns-token-here

#################################################
# Duplicati - Backup Service
#################################################
# Encryption key for Duplicati database
# CRITICAL: Generate a secure key and store it safely
# Generate with: openssl rand -base64 32
DUPLICATI_SETTINGS_ENCRYPTION_KEY=generate-a-secure-base64-key-here

#################################################
# Immich - Photo Management
#################################################
# Shared database password for all Immich services
# Used by: immich_machine_learning, immich_postgres, immich_server
# Generate with: openssl rand -base64 24
IMMICH_DB_PASSWORD=generate-a-secure-database-password

#################################################
# Plex - Media Server
#################################################
# Claim token for linking Plex server to your account
# Get token from: https://www.plex.tv/claim/
# Note: Claim tokens expire after 4 minutes - obtain just before use
PLEX_CLAIM_TOKEN=claim-your-token-here

#################################################
# Transmission - Torrent Client with VPN
#################################################
# Mullvad VPN credentials
# Get from: https://mullvad.net/account/
TRANSMISSION_OPENVPN_USERNAME=your-mullvad-account-number
TRANSMISSION_OPENVPN_PASSWORD=your-mullvad-password

# Transmission RPC credentials (optional, for remote control)
TRANSMISSION_RPC_USERNAME=
TRANSMISSION_RPC_PASSWORD=

# Transmission Web Proxy credentials (optional)
TRANSMISSION_WEBPROXY_USERNAME=
TRANSMISSION_WEBPROXY_PASSWORD=

#################################################
# Z-Wave JS UI - Smart Home Control
#################################################
# Session secret for securing web interface sessions
# Generate with: openssl rand -base64 32
ZWAVE_SESSION_SECRET=generate-a-secure-random-string
