# .env.example - Template for environment variables
# Copy this file to .env and fill in your actual values
# This file is safe to commit to version control

#################################################
# Shared Settings
#################################################
# Timezone (used by most services)
TZ=America/Chicago

# Default user/group IDs for container permissions
PUID=1000
PGID=1000

# Hostname for containers that need an explicit hostname
NOVA_HOSTNAME=nova

#################################################
# Traefik - Reverse Proxy
# Stack: infra (docker-compose.infra.yaml)
#################################################
# Base domain for Traefik subdomain routing (your DuckDNS domain)
NOVA_DOMAIN=firefly-koonan.duckdns.org

#################################################
# HTTPS / Let's Encrypt
# Stack: infra (docker-compose.infra.yaml)
#################################################
# Email for Let's Encrypt certificate expiry notifications
ACME_EMAIL=your-email@example.com

#################################################
# DuckDNS - Dynamic DNS Service
# Stack: infra (docker-compose.infra.yaml)
#################################################
# Token for updating DuckDNS records
# Get token from: https://www.duckdns.org/
# Also used by Traefik for DNS-01 challenge (ACME certificate issuance)
DUCKDNS_TOKEN=your-duckdns-token-here



#################################################
# Immich - Photo Management
# Stack: immich (docker-compose.immich.yaml)
#################################################
# Shared database password for all Immich services
# Used by: immich_machine_learning, immich_postgres, immich_server
# Generate with: openssl rand -base64 24
#################################################
# Immich - Photo Management
# Stack: immich (docker-compose.immich.yaml)
#################################################
# Shared database password for all Immich services
# Used by: immich_machine_learning, immich_postgres, immich_server
# Generate with: openssl rand -base64 24
IMMICH_DB_PASSWORD=pw
UPLOAD_LOCATION=path_in_container
DB_DATA_LOCATION=path_on_host
DB_USERNAME=postgres
DB_DATABASE_NAME=immich

#################################################
# Plex - Media Server
# Stack: media (docker-compose.media.yaml)
#################################################
# Claim token for linking Plex server to your account
# Get token from: https://www.plex.tv/claim/
# Note: Claim tokens expire after 4 minutes - obtain just before use
PLEX_CLAIM_TOKEN=claim-your-token-here

#################################################
# Gluetun + Transmission - Torrent Client with VPN
# Stack: media (docker-compose.media.yaml)
#################################################
# Mullvad WireGuard credentials
# Generate config at: https://mullvad.net/en/account/wireguard-config
# Download a WireGuard config file and extract values below
MULLVAD_WIREGUARD_PRIVATE_KEY=your-wireguard-private-key-base64
MULLVAD_WIREGUARD_ADDRESSES=10.x.x.x/32

# Server country for VPN exit (optional, defaults to Sweden)
#MULLVAD_SERVER_COUNTRY=Sweden

# Port forwarding port from Mullvad (optional)
#MULLVAD_WIREGUARD_PORT_FORWARD=

#################################################
# Z-Wave JS UI - Smart Home Control
# Stack: home (docker-compose.home.yaml)
#################################################
# Session secret for securing web interface sessions
# Generate with: openssl rand -base64 32
ZWAVE_SESSION_SECRET=generate-a-secure-random-string

#################################################
# Vibe Kanban - Project Management
# Stack: dev (docker-compose.dev.yaml)
#################################################
# GitHub Personal Access Token for GitHub CLI (gh) authentication
# Create at: https://github.com/settings/tokens
# Required scopes (classic PAT): repo, read:org
GH_TOKEN=your-github-token-here
