[Unit]
Description=Nova self-healing reconcile — recreate missing Docker containers
After=docker.service network-online.target
Requires=docker.service

[Service]
Type=oneshot
# Point to the nova-config .env for credentials. Adjust path if needed.
Environment=NOVA_ENV_FILE=/home/%u/nova-config/.env
ExecStart=/usr/local/bin/nova-reconcile.sh
StandardOutput=journal
StandardError=journal
SyslogIdentifier=nova-reconcile
