# .env.test.example - Template for TEST environment variables
# Copy this file to .env.test and fill in your actual values
# This file is safe to commit to version control
#
# The test environment uses the same variable names as .env
# but with separate values to avoid conflicts with production.
# Only variables that differ from .env need to be set here.
# If a variable is not set here, it falls back to the .env value.

#################################################
# Shared Settings
#################################################
TZ=America/Chicago
PUID=1000
PGID=1000
NOVA_HOSTNAME=nova-test

#################################################
# Traefik - Reverse Proxy
#################################################
NOVA_DOMAIN=firefly-koonan.duckdns.org
NOVA_TRAEFIK_SUFFIX=d

#################################################
# DuckDNS - Dynamic DNS Service
# Stack: infra (docker-compose.infra.yaml)
#################################################
# Typically not needed for test - uses same token
DUCKDNS_TOKEN=your-duckdns-token-here

#################################################
# Duplicati - Backup Service
# Stack: backup (docker-compose.backup.yaml)
#################################################
# Generate a SEPARATE key for test: openssl rand -base64 32
DUPLICATI_SETTINGS_ENCRYPTION_KEY=generate-a-separate-test-key-here

#################################################
# Immich - Photo Management
# Stack: immich (docker-compose.immich.yaml)
#################################################
# Generate a SEPARATE password for test: openssl rand -base64 24
IMMICH_DB_PASSWORD=generate-a-separate-test-password

#################################################
# Plex - Media Server (skipped in test by default)
# Stack: media (docker-compose.media.yaml)
#################################################
PLEX_CLAIM_TOKEN=claim-your-token-here

#################################################
# Gluetun + Transmission - Torrent Client with VPN
# Stack: media (docker-compose.media.yaml)
#################################################
MULLVAD_WIREGUARD_PRIVATE_KEY=your-wireguard-private-key-base64
MULLVAD_WIREGUARD_ADDRESSES=10.x.x.x/32
#MULLVAD_SERVER_COUNTRY=Sweden
#MULLVAD_WIREGUARD_PORT_FORWARD=

#################################################
# Z-Wave JS UI - Smart Home Control
# Stack: home (docker-compose.home.yaml)
#################################################
# Generate a SEPARATE secret for test: openssl rand -base64 32
ZWAVE_SESSION_SECRET=generate-a-separate-test-secret
